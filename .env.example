# Copy this file to .env before deployment and change the passwords.

# Web login password for the attendance console.
USER_PASSWORD=facecheck-user
USER_TOKEN_TTL_SEC=86400

# Admin login password for face registration and library management.
ADMIN_PASSWORD=facecheck-admin
ADMIN_TOKEN_TTL_SEC=43200
ADMIN_COOKIE_SECURE=auto

# Database and display settings.
DB_PATH=./data/face_database.db
DISPLAY_TZ_OFFSET_HOURS=8
ATTENDANCE_RETENTION_DAYS=3
AUTO_CHECKOUT_DAYS=3
ONLINE_INVALIDATE_HOURS=6
MAINTENANCE_POLL_SEC=60

# Browser-camera inference service.
CAM_SOURCE=cam1
WEBCAM_WS_BACKEND=ws://127.0.0.1:8765/ws/camera
WEBCAM_INTERNAL_REGISTER_URL=http://127.0.0.1:8765/internal/register-face
WEBCAM_INTERNAL_INFER_URL=http://127.0.0.1:8765/internal/infer-frame
WEB_ANALYSIS_WIDTH=640
WEB_ANALYSIS_HEIGHT=360
WEB_RESULT_JPEG_QUALITY=70
WEB_GESTURE_SCORE_THRESH=0.48
FEATURE_RELOAD_INTERVAL_SEC=2.0
ACTION_CONFIRM_FRAMES=3
FACE_DISTANCE_THRESHOLD=0.75
FACE_MARGIN_THRESHOLD=0.06

# Optional external system sync. Disabled by default.
EXTERNAL_SYNC_ENABLED=0
EXTERNAL_SYNC_URL=
EXTERNAL_SYNC_SECRET=
EXTERNAL_SYNC_BEARER_TOKEN=
EXTERNAL_SYNC_TIMEOUT_SEC=8
EXTERNAL_SYNC_MAX_ATTEMPTS=6
EXTERNAL_SYNC_POLL_SEC=2
